# Copy to .env and fill in from Supabase → Project Settings → API.
# Both values are safe to ship in the client; row-level security limits the
# anon key to reading published questions. Leave unset to run fully offline
# on the bundled question banks.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
